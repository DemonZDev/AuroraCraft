# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auroracraft?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="auroracraft-dev-secret-change-in-production-use-strong-random-key"
JWT_EXPIRES_IN="7d"

# Encryption Key (64 hex chars = 32 bytes for AES-256)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# File Storage
WORKSPACE_PATH=./data/workspaces
MAX_FILE_SIZE=52428800
MAX_ZIP_SIZE=104857600

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
