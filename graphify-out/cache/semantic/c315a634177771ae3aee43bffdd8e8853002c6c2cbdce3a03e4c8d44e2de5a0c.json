{"nodes": [{"id": "README_AuroraCraft", "label": "AuroraCraft Platform", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "README_AI_Plugin_Generation", "label": "AI Plugin Generation", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "README_OpenCode_Bridge", "label": "OpenCode AI Bridge", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "README_Firecrawl_MCP", "label": "Firecrawl MCP Integration", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Firecrawl MCP is a paid-only feature registered dynamically via OpenCode's HTTP API after instance starts, rather than being configured in opencode.json, to prevent Unrecognized key: mcpServers validation errors."}, {"id": "README_Per_User_Isolation", "label": "Per-User Linux Isolation", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each registered user gets a Linux system user (auroracraft-{username}) for file and process isolation. The server must run as root, or the auroracraft user must have passwordless sudo for adduser, userdel, chmod, chown, and runuser."}, {"id": "README_API_Key_Isolation", "label": "API Key Per-Project Isolation", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Provider API keys are never stored in the workspace tree; they are isolated per-project to prevent exposure through the code editor. Real provider config lives in /var/lib/auroracraft/configs with 600 permissions."}, {"id": "README_Shared_Caches", "label": "Shared Dependency Caches", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "777 permissions on shared caches is the simplest correct solution because each user runs as their own UID. A group-based approach would require a shared auroracraft group and sg on every runuser call, which is fragile."}], "edges": [{"source": "README_AuroraCraft", "target": "package_json_auroracraft", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.9, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "README_AuroraCraft", "target": "auroracraft_sh_management", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.9, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "README_AuroraCraft", "target": "server_package_backend", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.9, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "README_AuroraCraft", "target": "client_package_frontend", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.9, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "README_AI_Plugin_Generation", "target": "README_OpenCode_Bridge", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.9, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "README_Firecrawl_MCP", "target": "README_OpenCode_Bridge", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "README_Per_User_Isolation", "target": "README_API_Key_Isolation", "relation": "conceptually_related_to", "