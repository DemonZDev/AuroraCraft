# Database
DATABASE_URL=postgresql://auroracraft:auroracraft@localhost:5432/auroracraft

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Session — CHANGE THIS to a random 64-character hex string
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-secret

# Cookie domain — set to your domain in production
COOKIE_DOMAIN=localhost

# Client URL (for CORS and redirects) — must match your public URL
CLIENT_URL=http://localhost:3000

# OpenCode per-project instance settings
OPENCODE_PORT_MIN=9000
OPENCODE_PORT_MAX=9999
OPENCODE_IDLE_TIMEOUT=120000

# GitHub OAuth — fill in to enable GitHub repository integration
# 1. Create an OAuth App at https://github.com/settings/developers
# 2. Set Authorization callback URL to: {YOUR_DOMAIN}/api/auth/github/callback
# 3. Copy Client ID and Client Secret below
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_CALLBACK_URL=https://your-domain.com/api/auth/github/callback
